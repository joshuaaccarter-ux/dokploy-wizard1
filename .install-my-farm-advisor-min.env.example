# Dokploy Wizard My Farm Advisor focused env example
# Copy this file to .install.env, fill in operator-owned values, then chmod 0600 .install.env.
# Keep .install.env private and uncommitted. Never commit real passwords, tokens, API keys, or generated state secrets.
#
# All things < > needs to be updated and you do not keep the < > in your final value for the env variable
# Leave other stuff alone for now.
#

## Core stack identity
# Fill in 'ROOT_DOMAIN' with your target domain you purchased on Cloudflare, e.g. example.com.
ROOT_DOMAIN=<example.com>
TZ=America/New_York
PACKS=my-farm-advisor,nextcloud,seaweedfs,coder


## Cloudflare operator credentials
# Cloudflare Account ID + Cloudflare Zone ID: in the Cloudflare dashboard, open Account home, then click the domain you
#    purchaed, scroll to bottom on right, copy the Account ID and Zone ID.
# Cloudflare API token (https://dash.cloudflare.com/profile/api-tokens): create an API token, not a Global API Key.
#    Scope it only to this account and zone.
#   Minimum token permissions for the wizard:
#   - Account - Cloudflare One Connectors:Edit, Cloudflare One Connector: cloudflared:Edit, Cloudflare Tunnel:Edit
#   - Access: Organizations, Identity Providers, and Groups:Edit, Access: Apps and Policies:Edit
# Do not use a Cloudflare Global API Key. Do not grant all accounts or all zones unless this is a disposable test account.
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CLOUDFLARE_ZONE_ID=<cloudflare-zone-id>
CLOUDFLARE_API_TOKEN=<cloudflare-api-token>

## Dokploy bootstrap
# Set your own email and password so you can log in to your workspace apps
DOKPLOY_ADMIN_EMAIL=<operator@example.com>
DOKPLOY_ADMIN_PASSWORD=<strong-dokploy-admin-password>


## OpenRouter upstream provider (https://openrouter.ai/)
# Set your 'LITELLM_OPENROUTER_API_KEY'
LITELLM_OPENROUTER_API_KEY=<openrouter-api-key>
LITELLM_OPENROUTER_MODELS=deepseek/deepseek-v4-flash:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free,nousresearch/hermes-3-llama-3.1-405b:free,openai/gpt-5.5,~openai/gpt-latest,openai/gpt-5.3-codex,anthropic/claude-opus-4.7,anthropic/claude-sonnet-4.6,~anthropic/claude-opus-latest,~anthropic/claude-sonnet-latest,~anthropic/claude-haiku-latest,google/gemini-3.1-pro-preview,google/gemini-3.5-flash,~google/gemini-flash-latest,x-ai/grok-4.3,qwen/qwen3.7-max,google/gemini-3.1-flash-image-preview,deepseek/deepseek-v4-pro,deepseek/deepseek-v4-flash


## NVIDIA upstream provider (https://build.nvidia.com/explore/discover)
# Set your 'LITELLM_NVIDIA_API_KEY'
LITELLM_NVIDIA_API_KEY=<nvidia-api-key>
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1


## OpenCode Go upstream provider (https://opencode.ai/go?ref=PZ5MXT9E6J - $5 referral code)
# Set your 'LITELLM_OPENCODE_GO_API_KEY' to use OpenCode Go's API.
LITELLM_OPENCODE_GO_API_KEY=<opencode-go-api-key>
LITELLM_OPENCODE_GO_WILDCARD=true


## Default AI Provider Across Worspace Apps
AI_DEFAULT_PROVIDER=openrouter
AI_DEFAULT_MODEL=deepseek/deepseek-v4-flash:free
