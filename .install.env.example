# Dokploy Wizard install env example
# Copy this file to .install.env, fill in operator-owned values, then chmod 0600 .install.env.
# Keep .install.env private and uncommitted. Never commit real passwords, tokens, API keys, or generated state secrets.

## Core stack identity
ROOT_DOMAIN=example.com
TZ=UTC
PACKS=nextcloud,openclaw,my-farm-advisor,seaweedfs,coder,docuseal,surfsense
# Stack/project name defaults from ROOT_DOMAIN, for example example.com -> example-com.
# Uncomment only to preserve an existing explicit stack name.
# STACK_NAME=example-com

## Cloudflare operator credentials
# Cloudflare Account ID: in the Cloudflare dashboard, open Account home, then copy the account ID.
# Cloudflare Zone ID: open the target domain, then copy Zone ID from the Overview page API section.
# Cloudflare API token: create an API token, not a Global API Key. Scope it only to this account and zone.
# Minimum token permissions for the wizard:
# - Zone, DNS, Edit for the target zone, so the wizard can create and update tunnel DNS records.
# - Account, Cloudflare Tunnel, Edit for the target account. If your dashboard shows newer connector permissions, use Cloudflare One Connectors Write, Cloudflare One Connector: cloudflared Write, or Cloudflare Tunnel Write.
# - Account, Access Apps, Write/Edit and Account, Access Policies, Write/Edit only when Cloudflare Access OTP apps are enabled.
# Do not use a Cloudflare Global API Key. Do not grant all accounts or all zones unless this is a disposable test account.
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CLOUDFLARE_ZONE_ID=<cloudflare-zone-id>
CLOUDFLARE_API_TOKEN=<cloudflare-api-token>
CLOUDFLARE_ACCESS_OTP_EMAILS=operator@example.com

## Dokploy bootstrap
# Defaults to dokploy; uncomment only to override.
# DOKPLOY_SUBDOMAIN=dokploy
DOKPLOY_ADMIN_EMAIL=operator@example.com
DOKPLOY_ADMIN_PASSWORD=<strong-dokploy-admin-password>

## AI defaults through LiteLLM
# Upstream provider keys terminate at LiteLLM. App packs receive wizard-managed virtual keys.
AI_DEFAULT_PROVIDER=openrouter
AI_DEFAULT_MODEL=deepseek/deepseek-v4-flash:free
LITELLM_OPENROUTER_API_KEY=<openrouter-api-key>
LITELLM_OPENROUTER_MODELS=deepseek/deepseek-v4-flash:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free,nousresearch/hermes-3-llama-3.1-405b:free,openai/gpt-5.5,~openai/gpt-latest,openai/gpt-5.3-codex,anthropic/claude-opus-4.7,anthropic/claude-sonnet-4.6,~anthropic/claude-opus-latest,~anthropic/claude-sonnet-latest,~anthropic/claude-haiku-latest,google/gemini-3.1-pro-preview,google/gemini-3.5-flash,~google/gemini-flash-latest,x-ai/grok-4.3,qwen/qwen3.7-max,google/gemini-3.1-flash-image-preview,deepseek/deepseek-v4-pro,deepseek/deepseek-v4-flash

## Pack hostnames and safe defaults
# Defaults to farm when the my-farm-advisor pack is enabled; uncomment only to override.
# MY_FARM_ADVISOR_SUBDOMAIN=farm
SURFSENSE_SUBDOMAIN=surfsense
SURFSENSE_API_SUBDOMAIN=surfsense-api
SURFSENSE_ZERO_SUBDOMAIN=surfsense-zero
SURFSENSE_VERSION=0.0.25
NEXTCLOUD_OPENCLAW_RESCAN_CRON=0 */6 * * *
NEXTCLOUD_OPENCLAW_RESCAN_TIMEZONE=UTC

## Optional Docker Hub auth
# Set both values only if unauthenticated Docker Hub pulls hit rate limits during install/proof.
# DOCKER_USERNAME=<docker-hub-username>
# DOCKER_PAT=<docker-hub-personal-access-token>

## Optional private host access
# Use PACKS=headscale,... when the wizard should deploy Headscale. Use Tailscale values only for an existing tailnet path.
# ENABLE_TAILSCALE=false
# TAILSCALE_AUTH_KEY=<tailscale-auth-key>
# TAILSCALE_HOSTNAME=<tailnet-hostname>

## Optional Telegram channels
# Uncomment channel keys and tokens only when Telegram bots should be wired.
# OPENCLAW_CHANNELS=telegram
# OPENCLAW_TELEGRAM_BOT_TOKEN=<openclaw-telegram-bot-token>
# OPENCLAW_TELEGRAM_OWNER_USER_ID=<telegram-owner-user-id>
# MY_FARM_ADVISOR_CHANNELS=telegram
# MY_FARM_ADVISOR_TELEGRAM_BOT_TOKEN=<farm-telegram-bot-token>
# MY_FARM_ADVISOR_TELEGRAM_OWNER_USER_ID=<farm-telegram-owner-user-id>
# TELEGRAM_FIELD_OPERATIONS_BOT_TOKEN=<field-operations-bot-token>
# TELEGRAM_FIELD_OPERATIONS_BOT_PAIRING_CODE=<field-operations-pairing-code>
# TELEGRAM_FIELD_OPERATIONS_ALLOWED_USERS=<telegram-user-id-list>
# TELEGRAM_DATA_PIPELINE_BOT_TOKEN=<data-pipeline-bot-token>
# TELEGRAM_DATA_PIPELINE_BOT_PAIRING_CODE=<data-pipeline-pairing-code>
# TELEGRAM_DATA_PIPELINE_ALLOWED_USERS=<telegram-user-id-list>
# TELEGRAM_DATA_PIPELINE_BOT_ALLOWED_USERS=<telegram-user-id-list>
# TELEGRAM_ALLOWED_USERS=<telegram-user-id-list>
# OPENCLAW_TELEGRAM_GROUP_POLICY=allowlist

## Optional R2 data pipeline storage
# R2 is mounted only when all credentials are present and WORKSPACE_DATA_R2_RCLONE_MOUNT=1.
# DATA_MODE=volume
# WORKSPACE_DATA_R2_RCLONE_MOUNT=0
# WORKSPACE_DATA_R2_PREFIX=workspace/data
# R2_BUCKET_NAME=<r2-bucket-name>
# R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=<r2-access-key-id>
# R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# CF_ACCOUNT_ID=<cloudflare-account-id>

## Optional NVIDIA upstream provider
# LITELLM_NVIDIA_API_KEY=<nvidia-api-key>
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

## Optional OpenCode Go upstream provider
# LITELLM_OPENCODE_GO_API_KEY=<opencode-go-api-key>
# LITELLM_OPENCODE_GO_WILDCARD=true

## Optional local LLM upstream
# Keep this commented unless you intentionally route through a private OpenAI-compatible endpoint.
# LITELLM_LOCAL_BASE_URL=<local-openai-compatible-base-url>
# LITELLM_LOCAL_MODEL=<local-model-name>
# LITELLM_LOCAL_API_KEY=<local-model-api-key>

## Optional Nexa runtime integration
# Nexa values are server-owned runtime inputs. Leave commented unless you are intentionally enabling the embedded Nexa sidecar contract.
# OPENCLAW_NEXA_TALK_SHARED_SECRET=<nexa-talk-shared-secret>
# OPENCLAW_NEXA_TALK_SIGNING_SECRET=<nexa-talk-signing-secret>
# OPENCLAW_NEXA_ONLYOFFICE_CALLBACK_SECRET=<nexa-onlyoffice-callback-secret>
# OPENCLAW_NEXA_EDITOR_EVENTS_SHARED_SECRET=<nexa-editor-events-shared-secret>
# OPENCLAW_NEXA_PRESENCE_POLICY=trusted_proxy
# OPENCLAW_NEXA_NEXTCLOUD_BASE_URL=
# OPENCLAW_NEXA_WEBDAV_AUTH_USER=nexa
# OPENCLAW_NEXA_WEBDAV_AUTH_PASSWORD=<nexa-webdav-password>
# OPENCLAW_NEXA_AGENT_USER_ID=nexa
# OPENCLAW_NEXA_AGENT_DISPLAY_NAME=Nexa
# OPENCLAW_NEXA_AGENT_PASSWORD=<nexa-agent-password>
# OPENCLAW_NEXA_AGENT_EMAIL=nexa@example.com
# OPENCLAW_NEXA_MEM0_LLM_BASE_URL=
# OPENCLAW_NEXA_MEM0_LLM_API_KEY=<nexa-mem0-api-key>
# OPENCLAW_NEXA_MEM0_EMBEDDER_MODEL=text-embedding-3-small
# OPENCLAW_NEXA_MEM0_EMBEDDER_DIMENSIONS=1536
# OPENCLAW_NEXA_MEM0_VECTOR_BACKEND=qdrant
# OPENCLAW_NEXA_MEM0_VECTOR_DIMENSIONS=1536

## Generated/state-backed values, do not set for normal installs
# The wizard generates these values, stores them in state, and reuses them across reruns.
# DOKPLOY_API_KEY=
# DOKPLOY_PASSWORD=
# SEAWEEDFS_ACCESS_KEY=
# SEAWEEDFS_SECRET_KEY=
# OPENCLAW_GATEWAY_PASSWORD=
# OPENCLAW_GATEWAY_TOKEN=
# MY_FARM_ADVISOR_GATEWAY_PASSWORD=
# ADVISOR_GATEWAY_PASSWORD=
# SURFSENSE_SECRET_KEY=
# SURFSENSE_JWT_SECRET=
# SURFSENSE_DB_PASSWORD=
# SURFSENSE_ZERO_ADMIN_PASSWORD=
# SURFSENSE_SEARXNG_SECRET=
# SURFSENSE_LITELLM_VIRTUAL_KEY=
# LITELLM_VIRTUAL_KEY=
